@page "/pedidos/editar/{Id:guid}"

<div class="page-container">

    <div class="page-header">
        <h3 class="page-title d-flex align-items-center gap-2">
            <i class="bi bi-pencil-square"></i>
            <span>Editar Pedido</span>
        </h3>
        <p class="page-subtitle">Atualize os itens do pedido</p>
    </div>

    @if (IsLoading)
    {
        <div class="state-container">
            <div class="spinner-border text-primary"></div>
            <p>Carregando dados...</p>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">

            <div class="card-body">

                <div class="row">

                    @foreach (var item in Itens)
                    {
                        <div class="col-md-4 mb-3">

                            <div class="item-card @(ItemSelecionado[item.Id] ? "selected" : "")"
                                 @onclick="() => ToggleItem(item.Id)">

                                <div class="d-flex justify-content-between align-items-center">

                                    <div>
                                        <div class="fw-semibold">@item.Nome</div>

                                        <small class="text-muted">
                                            @item.Preco.ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                                        </small>

                                        <div class="small text-secondary">
                                            @GetTipoDescricao(item.Tipo)
                                        </div>
                                    </div>

                                    <div class="form-check">
                                        <input class="form-check-input"
                                               type="checkbox"
                                               checked="@ItemSelecionado[item.Id]"
                                               readonly />
                                    </div>

                                </div>

                            </div>

                        </div>
                    }

                </div>

            </div>

            <div class="card mt-4 summary-card">

                <div class="card-body d-flex justify-content-between align-items-center">

                    <button class="btn btn-outline-secondary"
                            @onclick="Voltar">
                        <i class="bi bi-arrow-left me-1"></i>
                        Cancelar
                    </button>

                    <button class="btn btn-primary"
                            @onclick="Actualizar"
                            disabled="@IsSaving">

                        @if (IsSaving)
                        {
                            <span class="spinner-border spinner-border-sm me-2"></span>
                            <span>Salvando</span>
                        }
                        else
                        {
                            <i class="bi bi-check-circle me-1"></i>
                            <span>Actualizar Pedido</span>
                        }

                    </button>

                </div>

            </div>

        </div>
    }

    @if (!string.IsNullOrEmpty(Mensagem))
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3">

            <div class="toast show @(Sucesso ? "bg-success text-white" : "bg-danger text-white")">

                <div class="d-flex flex-column">

                    <div class="toast-body fw-semibold">
                        @Mensagem
                    </div>

                    @if (Erros != null && Erros.Any())
                    {
                        <ul class="mb-0 ps-4 pb-2">
                            @foreach (var erro in Erros)
                            {
                                <li>@erro</li>
                            }
                        </ul>
                    }

                </div>

                <button class="btn position-absolute end-0 m-2 text-white"
                        style="background: transparent; border: none;"
                        @onclick="LimparMensagem"
                        aria-label="Fechar alerta">

                    <i class="bi bi-x-lg fs-5"></i>

                </button>

            </div>

        </div>
    }

</div>