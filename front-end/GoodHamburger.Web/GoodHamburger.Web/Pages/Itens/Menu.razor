@page "/menu"

<div class="page-container">

    <div class="page-header">
        <h3 class="page-title">🍔 Menu</h3>
        <p class="page-subtitle">Selecione os itens para criar um pedido</p>
    </div>

    @if (IsLoading)
    {
        <div class="state-container">
            <div class="spinner-border text-primary"></div>
            <p>Carregando itens...</p>
        </div>
    }
    else if (Itens == null || !Itens.Any())
    {
        <div class="state-container">
            <div class="state-icon">📭</div>
            <p>Nenhum item disponível</p>
        </div>
    }
    else
    {
        <!-- GRID DE ITENS -->
        <div class="row">
            @foreach (var item in Itens)
            {
                <div class="col-md-4 mb-3">

                    <div class="item-card @(ItemSelecionado[item.Id] ? "selected" : "")"
                         @onclick="() => ToggleItem(item.Id)">

                        <div class="d-flex justify-content-between align-items-center">

                            <div>
                                <div class="fw-semibold">@item.Nome</div>
                                <small class="text-muted">@item.Preco.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</small>
                            </div>

                            <div class="form-check">
                                <input class="form-check-input"
                                       type="checkbox"
                                       checked="@ItemSelecionado[item.Id]"
                                       readonly />
                            </div>

                        </div>

                    </div>

                </div>
            }
        </div>

        <!-- RESUMO -->
        <div class="card mt-4 summary-card">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>
                    <div><strong>Itens:</strong> @ItensSelecionadosCount</div>
                    <div><strong>Total:</strong> @TotalSelecionado.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</div>
                </div>

                <button class="btn btn-primary"
                        @onclick="FazerPedido"
                        disabled="@IsSubmitting">

                    @if (IsSubmitting)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>Processando</span>
                    }
                    else
                    {
                        <span>Finalizar Pedido</span>
                    }

                </button>

            </div>

        </div>

    }

    @if (!string.IsNullOrEmpty(Mensagem))
    {
        <div class="toast-container position-fixed bottom-0 end-0 p-3">

            <div class="toast show @(Sucesso ? "bg-success text-white" : "bg-danger text-white")">

                <div class="d-flex flex-column">

                    <div class="toast-body fw-semibold">
                        @Mensagem
                    </div>

                    @if (Erros != null && Erros.Any())
                    {
                        <ul class="mb-0 ps-4 pb-2">
                            @foreach (var erro in Erros)
                            {
                                <li>@erro</li>
                            }
                        </ul>
                    }

                </div>

                <button class="btn-close btn-close-white position-absolute end-0 m-2"
                        @onclick="LimparMensagem">
                </button>

            </div>

        </div>
    }

</div>